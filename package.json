{
  "name": "wesdeal",
  "version": "0.1.0",
  "description": "A bridge deal generator: random layouts consistent with constraints.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "research:gen": "vitest run -c vitest.research.config.ts gen",
    "research:analyze": "vitest run -c vitest.research.config.ts analyze",
    "research:bidding": "vitest run -c vitest.research.config.ts bidding",
    "research:systems": "vitest run -c vitest.research.config.ts systems",
    "bridge:test": "vitest run -c bridge-wc.vitest.config.ts parse.test",
    "bridge:scrape": "vitest run -c bridge-wc.vitest.config.ts scrape.task",
    "bridge:flatten": "vitest run -c bridge-wc.vitest.config.ts flatten.task"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "bridge-dds": "1.4.0"
  }
}
